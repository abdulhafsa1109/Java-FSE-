<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Event Gallery</title>

    <style>
        table {
            margin: auto;
        }

        .event-img {
            width: 200px;
            height: 150px;
            border: 3px solid black;
        }

        td {
            text-align: center;
            padding: 10px;
        }
    </style>
</head>

<body>

<h2>Community Event Gallery</h2>

<table>
    <tr>
        <td>
            <img src="event1.jpg" alt="Music Event"
                 title="Music Event" class="event-img">
            <p>Music Event</p>
        </td>

        <td>
            <img src="event2.jpg" alt="Sports Event"
                 title="Sports Event" class="event-img">
            <p>Sports Event</p>
        </td>

        <td>
            <img src="event3.jpg" alt="Food Festival"
                 title="Food Festival" class="event-img">
            <p>Food Festival</p>
        </td>
    </tr>

    <tr>
        <td>
            <img src="event4.jpg" alt="Art Exhibition"
                 title="Art Exhibition" class="event-img">
            <p>Art Exhibition</p>
        </td>

        <td>
            <img src="event5.jpg" alt="Dance Event"
                 title="Dance Event" class="event-img">
            <p>Dance Event</p>
        </td>

        <td>
            <img src="event6.jpg" alt="Community Meeting"
                 title="Community Meeting" class="event-img">
            <p>Community Meeting</p>
        </td>
    </tr>
</table>

</body>
</html>
