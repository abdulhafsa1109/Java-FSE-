<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Debugging Example</title>
</head>

<body>

<h2 id="heading">Chrome DevTools Example</h2>

<button onclick="calculate()">
    Click Me
</button>

<p id="result"></p>

<script>

    console.log("Page loaded successfully");

    function calculate() {

        let a = 10;
        let b = 20;

        let sum = a + b;

        console.log("Value of a:", a);
        console.log("Value of b:", b);
        console.log("Sum:", sum);

        document.getElementById("result").innerHTML =
            "Sum = " + sum;
    }

</script>

</body>
</html>
